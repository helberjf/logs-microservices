{
  "name": "logs-microservice",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev:api": "node --watch --env-file=.env src/api/server.js",
    "dev:worker": "node --watch --env-file=.env src/worker/worker.js",
    "start:api": "node --env-file=.env src/api/server.js",
    "start:worker": "node --env-file=.env src/worker/worker.js",
    "lint": "eslint .",
    "format": "prettier -w .",
    "test": "vitest run",
    "test:watch": "vitest",
    "migrate": "node --env-file=.env scripts/migrate.js"
  },
  "dependencies": {
    "bullmq": "^5.19.0",
    "cors": "^2.8.6",
    "dotenv": "^16.4.5",
    "express": "^5.2.1",
    "express-rate-limit": "^8.4.0",
    "helmet": "^8.1.0",
    "ioredis": "^5.4.1",
    "pg": "^8.12.0",
    "pino": "^9.4.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.13.5",
    "eslint": "^9.19.0",
    "eslint-config-prettier": "^10.0.1",
    "prettier": "^3.4.2",
    "supertest": "^7.2.2",
    "vitest": "^2.1.9"
  }
}
